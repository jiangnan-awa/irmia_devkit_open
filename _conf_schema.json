{
  "tool_groups": {
    "description": "工具组开关（关闭整组禁用该组所有工具，需重启生效）",
    "type": "object",
    "items": {
      "安全编辑链": { "type": "bool", "default": true },
      "Git & GitHub": {
        "type": "object",
        "description": "Git 操作（含 GitHub CLI）",
        "items": {
          "_enabled": { "type": "bool", "default": true, "description": "启用本组" },
          "git_status": { "type": "bool", "default": true, "description": "查看仓库状态" },
          "git_diff": { "type": "bool", "default": true, "description": "查看差异" },
          "git_log": { "type": "bool", "default": true, "description": "查看提交记录" },
          "git_commit": { "type": "bool", "default": true, "description": "提交更改" },
          "git_branch": { "type": "bool", "default": true, "description": "当前分支" },
          "git_remote": { "type": "bool", "default": true, "description": "远程仓库URL" },
          "git_push": { "type": "bool", "default": true, "description": "推送到远程" },
          "gh_cli": { "type": "bool", "default": true, "description": "GitHub CLI" }
        }
      },
      "文件系统": { "type": "bool", "default": true },
      "系统信息": { "type": "bool", "default": true },
      "网络": { "type": "bool", "default": true },
      "文本处理": { "type": "bool", "default": true },
      "编码": { "type": "bool", "default": true },
      "时间": { "type": "bool", "default": true },
      "扩展": { "type": "bool", "default": true }
    }
  },
  "disabled_tools": {
    "description": "单独禁用的工具名（逗号分隔，如 git_push,svg_render）",
    "type": "string",
    "default": ""
  },
  "paths": {
    "description": "外部工具路径（留空 = 自动检测）",
    "type": "object",
    "items": {
      "es_path": {
        "description": "Everything CLI (es.exe) 路径",
        "type": "string",
        "default": ""
      },
      "gh_path": {
        "description": "GitHub CLI (gh.exe) 路径",
        "type": "string",
        "default": ""
      },
      "state_dir": {
        "description": "异步任务状态文件目录",
        "type": "string",
        "default": ""
      },
      "lock_dirs": {
        "description": "文件锁检测目录（逗号分隔）",
        "type": "string",
        "default": ""
      },
      "backup_dir": {
        "description": "safe_edit 备份目录",
        "type": "string",
        "default": ""
      }
    }
  }
}
